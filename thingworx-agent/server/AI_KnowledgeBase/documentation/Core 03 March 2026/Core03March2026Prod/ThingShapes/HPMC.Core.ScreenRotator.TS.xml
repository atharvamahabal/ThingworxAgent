                <ServiceImplementation
                 description=""
                 handlerName="Script"
                 name="HandleScreenRotation">
                    <ConfigurationTables>
                        <ConfigurationTable
                         dataShapeName=""
                         description=""
                         isMultiRow="false"
                         name="Script"
                         ordinal="0">
                            <DataShape>
                                <FieldDefinitions>
                                    <FieldDefinition
                                     baseType="STRING"
                                     description="code"
                                     name="code"
                                     ordinal="0"></FieldDefinition>
                                    <FieldDefinition
                                     baseType="JSON"
                                     description=""
                                     name="editorSettings"
                                     ordinal="0"></FieldDefinition>
                                </FieldDefinitions>
                            </DataShape>
                            <Rows>
                                <Row>
                                    <code>
                                    <![CDATA[
                                    /*
                                     * @name HandleScreenRotation
                                     * @date 21.03.2024
                                     * @author Marc Aurel Büttner
                                     * @return IT: URL of next screen, duration current screen, isActive
                                     */
                                    
                                    const getNextScreenOrder = (configuredPageCount) => {
                                      const currentScreenOrder = Number(currentLink ? currentLink.split("reloadIndicator=")[1] : 0) || 0;
                                      return configuredPageCount <= currentScreenOrder + 1 ? 0 : currentScreenOrder + 1;
                                    };
                                    
                                    const getDefaultResult = () => {
                                      const emptyResult = Resources["InfoTableFunctions"].CreateInfoTableFromDataShape({
                                        dataShapeName: "HPMC.Core.ScreenRotator.DS"
                                      });
                                      emptyResult.AddRow({
                                        forwardUrl: undefined, // STRING
                                        currentDuration: undefined, // NUMBER
                                        isActive: false // BOOLEAN
                                      });
                                      return emptyResult;
                                    };
                                    
                                    try {
                                      const updateSessionAndGetRotationData = () => {
                                        const currentSessionValues = Resources["CurrentSessionInfo"].GetGlobalSessionValues();
                                    
                                        if (!currentSessionValues.screenRotationEnabled) {
                                          return getDefaultResult();
                                        }
                                    
                                        const { selectedLocations: locationContext, screenRotationCollection: collectionContext } = currentSessionValues;
                                    
                                        const currentRotationScreenCollection = Things["HPMC.Core.RotatingScreen.DT"].QueryDataTableEntries({
                                          maxItems: undefined /* NUMBER {"defaultValue":500} */,
                                          values: Things["HPMC.Core.RotatingScreen.DT"].CreateValuesWithData({
                                            values: {
                                              locId: locationContext.locId,
                                              ucId: locationContext.ucId,
                                              collection: collectionContext
                                            } /* JSON */
                                          }) /* INFOTABLE */
                                        });
                                    
                                        const { datasetConfiguration: configuredPages, duration: collectionDuration } = currentRotationScreenCollection;
                                    
                                        const nextScreenOrder = getNextScreenOrder(configuredPages.getRowCount());
                                        // const nextScreenOrder = configuredPages.getRowCount() == currentSessionValues.screenRotationOrder + 1 ? 0 : currentSessionValues.screenRotationOrder + 1;
                                        const nextPageConfig = configuredPages.getRow(nextScreenOrder);
                                    
                                        Resources["CurrentSessionInfo"].SetGlobalSessionNumberValue({
                                          name: "screenRotationOrder" /* STRING */,
                                          value: nextScreenOrder /* NUMBER */
                                        });
                                          
                                          logger.info("HandleScreenRotation Line 56 "+nextScreenOrder);
                                    
                                        Resources["CurrentSessionInfo"].SetGlobalSessionInfoTableValue({
                                          name: "selectedMachineGroups" /* STRING */,
                                          value: nextPageConfig.machineGroups
                                        });
                                          logger.info("HandleScreenRotation Line 63 " + nextPageConfig.selectedAssets.getRowCount());
                                    
                                        Resources["CurrentSessionInfo"].SetGlobalSessionInfoTableValue({
                                          name: "selectedMachineTypes" /* STRING */,
                                          value: me.GetMachineTypeByType({
                                            machineType: nextPageConfig.machineType /* STRING */
                                          }) /* INFOTABLE */
                                        });
                                    
                                        Resources["CurrentSessionInfo"].SetGlobalSessionInfoTableValue({
                                          name: "selectedAssets" /* STRING */,
                                          value: nextPageConfig.selectedAssets /* INFOTABLE */
                                        });
                                    
                                        Resources["CurrentSessionInfo"].SetGlobalSessionStringValue({
                                          name: "screenRotationTimePeriod" /* STRING */,
                                          value: nextPageConfig.period /* STRING */
                                        });
                                        Resources["CurrentSessionInfo"].SetGlobalSessionStringValue({
                                          name: "screenRotationChangeDuration" /* STRING */,
                                          value: nextPageConfig.duration ? nextPageConfig.duration : collectionDuration /* STRING */
                                        });
                                    
                                        Resources["CurrentSessionInfo"].SetGlobalSessionBooleanValue({
                                          name: "is24hView" /* STRING */,
                                          value: nextPageConfig.is24hView /* STRING */
                                        });
                                        Resources["CurrentSessionInfo"].SetGlobalSessionBooleanValue({
                                          name: "isGroupView" /* STRING */,
                                          value: nextPageConfig.isGroupView /* STRING */
                                        });
                                    
                                        const correspondingLocation = me.GetLocationById({
                                          locId: locationContext.locId /* STRING */
                                        });
                                        // logger.error(me.name + ".HandleScreenRotation: nextGroup[" + nextPageConfig.machineGroup + "] nextMzu[" + nextPageConfig.mashup + "]");
                                    
                                        const rotationData = Resources["InfoTableFunctions"].CreateInfoTableFromDataShape({
                                          dataShapeName: "HPMC.Core.ScreenRotator.DS"
                                        });
                                        rotationData.AddRow({
                                          forwardUrl:
                                            me.serverRootUrl +
                                            "/Runtime/index.html?#master=" +
                                            me.solutionMaster +
                                            "&__applyThemeName=HPMC.Core.Default.Black.Style&mashup=" +
                                            nextPageConfig.mashup +
                                            "&reloadIndicator=" +
                                            nextScreenOrder +
                                            (!nextPageConfig.staticContent
                                              ? ""
                                              : "&imageURL=/Thingworx/FileRepositories/HPMC.Core.Repository/StaticScreen/" +
                                                correspondingLocation.locId +
                                                "_" +
                                                correspondingLocation.ucId +
                                                "/" +
                                                nextPageConfig.staticContent), // STRING
                                          currentDuration: configuredPages[currentSessionValues.screenRotationOrder].duration ? configuredPages[currentSessionValues.screenRotationOrder].duration : collectionDuration, // NUMBER
                                          isActive: true // BOOLEAN
                                        });
                                        return rotationData;
                                      };
                                    
                                      /* BEGIN SERVICE */
                                      // Pause code is necessary for the dropdown filters to work properly
                                      //Pause is updated from 2000 to 13000 as the service execution and mashup loading time was not matching 
                                      pause(13000);
                                      result = updateSessionAndGetRotationData();
                                    } catch (err) {
                                      logger.error("Error at " + me.name + ".HandleScreenRotation [" + err.lineNumber + "]:" + err.message);
                                      result = getDefaultResult();
                                    }
                                    ]]>
                                    </code>
                                    <editorSettings>
                                        <json>
                                        <![CDATA[
                                        {"viewState":{"viewState":{"firstPositionDeltaTop":-10,"scrollLeft":0,"firstPosition":{"column":1,"lineNumber":117}},"cursorState":[{"inSelectionMode":false,"selectionStart":{"column":107,"lineNumber":128},"position":{"column":107,"lineNumber":128}}],"contributionsState":{"editor.contrib.wordHighlighter":false,"editor.contrib.folding":{"provider":"indent","lineCount":135,"foldedImports":false}}}}
                                        ]]>
                                        </json>
                                    </editorSettings>
                                </Row>
                            </Rows>
                        </ConfigurationTable>
