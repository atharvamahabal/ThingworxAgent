                                        <code>
                                        <![CDATA[
                                        /*
                                        * @name IsDaylightSavingTimeActive
                                        * @author Georg Reckendorfer
                                        * @return true if summer time is currently active
                                        */
                                        
                                        function isDaylightSavingTime() {
                                            var today = new Date();
                                            var year = today.getFullYear();
                                            var lastSundayMarch = getLastSundayOfMonth(2, year); // März ist der dritte Monat (0-basiert)
                                            var lastSundayOctober = getLastSundayOfMonth(9, year); // Oktober ist der zehnte Monat (0-basiert)
                                        	logger.info("LastSundayMarch = " + lastSundayMarch);
                                            logger.info("LastSundayOctober =" + lastSundayOctober);
                                            logger.info("Today = " + today);
                                            return today >= lastSundayMarch && today < lastSundayOctober;
                                        }
                                        
                                        function getLastSundayOfMonth(month, year) {
                                            var lastDayOfMonth = new Date(year, month + 1, 0); // Letzter Tag des Monats
                                            var dayOfWeek = lastDayOfMonth.getDay(); // Wochentag des letzten Tages des Monats
                                            return new Date(year, month, lastDayOfMonth.getDate() - dayOfWeek); // Letzter Sonntag des Monats
                                        }
                                        
                                        var result = isDaylightSavingTime();
                                        ]]>
                                        </code>
                                    </Row>
                                </Rows>
