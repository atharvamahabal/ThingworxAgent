                                        <code>
                                        <![CDATA[
                                        /*
                                        * @name SetCorrectTimeOffsetForEachLocation
                                        * @author Georg Reckendorfer
                                        * @return nothing
                                        *
                                        * Service will if daylight saving time is active 
                                        * then it iterates through all locations and set the correct timezoneoffset 
                                        */
                                        const isDaylightSavingTimeActive = me.IsDaylightSavingTimeActive();
                                        
                                        let allLocationThings = ThingTemplates["HPMC.Core.Location.TT"].QueryImplementingThingsWithData({}); 
                                        
                                        allLocationThings.rows.toArray().forEach(location => {
                                            let locationName = location.name;
                                           
                                            let locationThing = Things[locationName];
                                            logger.info("locationName = " + locationName + ", hasDST="+locationThing.hasDST+", active="+isDaylightSavingTimeActive);
                                        
                                            if (locationThing.hasDST && isDaylightSavingTimeActive) {
                                                locationThing.timezoneOffset = locationThing.standardTimezoneOffset + 60;
                                                logger.info("locationName = " + locationName + " - set day light saving time.");
                                            } else {
                                                locationThing.timezoneOffset = locationThing.standardTimezoneOffset;
                                        		logger.info("locationName = " + locationName + " - set standard time.");
                                            }
                                        });
                                        ]]>
                                        </code>
                                    </Row>
                                </Rows>
                            </ConfigurationTable>
                        </ConfigurationTables>
